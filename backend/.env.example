# Optional max upload size in bytes (default: 2097152 = 2MB)
# MAX_IMAGE_UPLOAD_BYTES=2097152

# Cloudinary (required when UPLOAD_STORAGE=cloud)
CLOUDINARY_CLOUD_NAME=quickcv
